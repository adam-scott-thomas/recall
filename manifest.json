{
  "manifest_version": 3,
  "name": "Recall",
  "version": "0.1.0",
  "description": "Search your AI conversation history. Fully local, open source.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "options_page": "src/options/options.html",
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  }
}
